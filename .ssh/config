Host kerrigan
    User vboysepe
    IdentityFile ~/.ssh/ans
    IdentitiesOnly yes
    ProxyCommand bash -c 'nc -z -w1 10.0.1.177 22 2>/dev/null && exec nc 10.0.1.177 %p || exec nc kerrigan.kity.love %p'

