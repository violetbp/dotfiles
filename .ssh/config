Host haos 
    User hassio
    HostName 10.0.0.7
    Port 2272

# nc -z -w2 10.0.1.177 22 — connect to port 22 on the direct IP, but -z means "just probe, don't send data" and -w2 means "give up after 2 seconds". This is the home network check.
# 2>/dev/null — silence any error output from the probe
# && exec nc 10.0.1.177 %p — if the probe succeeded (exit 0), replace the bash process with nc piped directly to the LAN IP. %p is SSH's placeholder for the port number (22).
# || exec nc kerrigan.kity.love %p — if the probe failed, fall back to the VPN hostname instead.

# could use timeout for even faster failover
# ProxyCommand bash -c 'timeout 0.5 nc -z 10.0.1.177 22 2>/dev/null && exec nc 10.0.1.177 %p || exec nc kerrigan.kity.love %p'


