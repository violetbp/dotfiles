Host *
    Port 22
    IgnoreUnknown AddKeysToAgent,UseKeychain
    UseKeychain yes
    AddKeysToAgent yes
    IdentityFile ~/.ssh/id_rsa
    ControlMaster auto
    ControlPath ~/.ssh/_%r@%h:%p
    ControlPersist 43200
    SetEnv TERM=xterm
